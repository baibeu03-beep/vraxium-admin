{
  "name": "vraxium-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sync:schools": "tsx --env-file=.env.local scripts/sync-schools.ts",
    "sync:grade-stats": "tsx --env-file=.env.local scripts/sync-grade-stats.ts",
    "verify:grade-stats-sync": "tsx --env-file=.env.local scripts/verify-grade-stats-sync.ts",
    "verify:batch-saturation-guard": "tsx --env-file=.env.local scripts/verify-batch-saturation-guard.ts",
    "verify:cluster4-submission-fields": "tsx --env-file=.env.local scripts/verify-cluster4-submission-fields.ts",
    "backfill:weekly-card-snapshots": "tsx --env-file=.env.local scripts/backfill-weekly-card-snapshots.ts",
    "crawler": "tsx --env-file=.env.local crawler/server.ts",
    "crawler:seed": "node scripts/naver-session-seed.mjs",
    "verify:cafe-crawler-contract": "tsx scripts/verify-cafe-crawler-contract.ts",
    "verify:cafe-crawler-client": "tsx scripts/verify-cafe-crawler-client.ts",
    "verify:cafe-match-scope": "tsx --env-file=.env.local scripts/verify-cafe-match-scope-unit.ts",
    "verify:scope-helper-usage": "tsx scripts/verify-scope-helper-usage.ts",
    "verify:scope-centralization": "tsx --env-file=.env.local scripts/verify-scope-centralization-phase1.ts",
    "verify:scope": "npm run verify:scope-helper-usage && npm run verify:scope-centralization",
    "verify:admin-mode-p1": "tsx --env-file=.env.local scripts/verify-admin-mode-p1.ts",
    "verify:admin-mode-p1-browser": "tsx --env-file=.env.local scripts/verify-admin-mode-p1-browser.ts",
    "verify:applicants-approve-all": "tsx --env-file=.env.local scripts/verify-applicants-approve-all.ts",
    "verify:zerotarget-info-policy": "tsx --env-file=.env.local scripts/verify-zerotarget-info-policy.ts",
    "apply:qa-overlay": "tsx --env-file=.env.local scripts/apply-qa-overlay-state.ts",
    "verify:qa-overlay-direct": "tsx --env-file=.env.local scripts/verify-qa-overlay-direct.ts",
    "verify:qa-overlay-http": "tsx --env-file=.env.local scripts/verify-qa-overlay-http.ts",
    "seed:qa-summer-season": "tsx --env-file=.env.local scripts/seed-qa-test-users-summer-season.ts",
    "verify:qa-roster-seed": "tsx --env-file=.env.local scripts/verify-qa-roster-seed.ts",
    "verify:qa-fixed-scope": "tsx --env-file=.env.local scripts/verify-qa-fixed-scope.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.105.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "mysql2": "^3.22.4",
    "playwright-core": "^1.60.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
