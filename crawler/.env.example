# 카페 크롤러 서비스 환경변수 (크롤러 PC 전용)
# 실제 값은 repo 루트의 .env.local 에 두고 `npm run crawler` 로 구동한다(--env-file=.env.local).

# Vercel ↔ 크롤러 공유 시크릿(양쪽 동일값). 길고 무작위로.
CAFE_CRAWLER_SECRET=change-me-to-a-long-random-string

# 크롤러 리슨 포트(Cloudflare Tunnel ingress 가 가리키는 포트).
CAFE_CRAWLER_PORT=8787

# 세션 시드 자동입력 보조용(런타임 미사용). 캡차/기기/2FA 는 사람이 창에서 통과.
# NAVER_ID=...
# NAVER_PASSWORD=...
